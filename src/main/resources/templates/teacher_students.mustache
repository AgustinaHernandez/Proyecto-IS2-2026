{{> header}}

<body class="bg-gray-100 dark:bg-gray-900 min-h-screen p-8 transition-colors duration-300">
    
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-800 dark:text-white mb-6">Alumnos Inscriptos {{#subjectName}}- {{subjectName}}{{/subjectName}}</h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow mb-8 border border-gray-200 dark:border-gray-700">
            <form action="/teacher/subject-students" method="get" class="flex gap-4">
                
                {{#subjectId}}
                <input type="hidden" name="subject_id" value="{{subjectId}}">
                {{/subjectId}}

                <div class="flex-grow">
                    <input type="text" name="q" value="{{query}}" placeholder="Buscar alumno por nombre, apellido o DNI..." 
                           class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white">
                </div>
                <button type="submit" class="bg-blue-600 text-white py-2 px-6 rounded-md hover:bg-blue-700 transition-colors">
                    Buscar
                </button>
            </form>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden border border-gray-200 dark:border-gray-700">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
                        <th class="py-3 px-6 text-sm font-semibold text-gray-700 dark:text-gray-300">DNI</th>
                        <th class="py-3 px-6 text-sm font-semibold text-gray-700 dark:text-gray-300">Nombre Completo</th>
                        <th class="py-3 px-6 text-sm font-semibold text-gray-700 dark:text-gray-300">Email</th>
                        <th class="py-3 px-6 text-sm font-semibold text-gray-700 dark:text-gray-300">Condición</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    
                    {{#students}}
                    <tr class="hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors">
                        <td class="py-3 px-6 text-sm text-gray-900 dark:text-white font-medium">{{getDNI}}</td>
                        <td class="py-3 px-6 text-sm text-gray-700 dark:text-gray-300">{{getFullNameString}}</td>
                        <td class="py-3 px-6 text-sm text-gray-700 dark:text-gray-300">{{getEmail}}</td>
                        <td class="py-3 px-6 text-sm text-gray-700 dark:text-gray-300">
                            <span class="px-2 py-1 bg-gray-200 dark:bg-gray-600 text-gray-800 dark:text-gray-200 rounded text-xs font-semibold">
                                {{getCondition}}
                            </span>
                        </td>
                    </tr>
                    {{/students}}
                    
                    {{^students}}
                    <tr>
                        <td colspan="4" class="py-8 text-center text-gray-500 dark:text-gray-400">
                            No se encontraron alumnos inscriptos con esos datos
                        </td>
                    </tr>
                    {{/students}}

                </tbody>
            </table>
        </div>

        <div class="mt-6 flex justify-center items-center gap-4">
            {{#hasPrev}}
            <a href="/teacher/subject-students?q={{query}}{{#subjectId}}&subject_id={{subjectId}}{{/subjectId}}&page={{prevPage}}" class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-md hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors font-medium">
                &larr; Anterior
            </a>
            {{/hasPrev}}

            {{#hasNext}}
            <a href="/teacher/subject-students?q={{query}}{{#subjectId}}&subject_id={{subjectId}}{{/subjectId}}&page={{nextPage}}" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors font-medium">
                Siguiente &rarr;
            </a>
            {{/hasNext}}

        </div>

        <div class="mt-6 text-center">
            <a href="/dashboard" class="text-blue-600 dark:text-blue-400 hover:underline">← Volver al Dashboard</a>
        </div>
    </div>

</body>
</html>