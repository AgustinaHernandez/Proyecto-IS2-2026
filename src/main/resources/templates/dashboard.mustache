{{> header}}

<!-- Agregamos dark:bg-gray-900 para el fondo general -->
<body class="bg-gray-100 dark:bg-gray-900 flex items-center justify-center min-h-screen p-4 transition-colors duration-300">
    
    <!-- Agregamos dark:bg-gray-800 para el fondo de la tarjeta principal -->
    <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-4xl border border-gray-200 dark:border-gray-700">
        
        <!-- Texto oscuro cambia a blanco -->
        <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mb-6">Panel de Control</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 dark:text-gray-300 mb-8">¡Bienvenido, <span class="font-semibold text-blue-600 dark:text-blue-400">{{username}}</span>!</p>
        {{/username}}
        {{^username}}
        <p class="text-xl text-center text-gray-700 dark:text-gray-300 mb-8">¡Bienvenido!</p>
        {{/username}}

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            
            <!-- TARJETA PERFIL -->
            <!-- En modo oscuro: fondo azul muy oscuro y bordes tenues -->
            <div class="bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-blue-700 dark:text-blue-300 mb-3">Tu Perfil</h2>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Gestiona la información de tu cuenta.</p>
                <a href="/profile" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Perfil</a>
            </div>
            
            <!-- TARJETA CONFIGURACIÓN -->
            <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 dark:text-green-300 mb-3">Configurar</h2>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Ajusta las preferencias de tu aplicación.</p>
                <a href="/settings" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Configuración</a>
            </div>
            
            <!-- TARJETA PROFESORES -->
            {{#is_admin}}
            <div class="bg-yellow-50 dark:bg-yellow-900/30 border border-yellow-200 dark:border-yellow-800 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-yellow-700 dark:text-yellow-300 mb-3">Profesores</h2>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Agrega un profesor al sistema.</p>
                <a href="/teacher/create" class="inline-block bg-yellow-500 text-white py-2 px-4 rounded-md hover:bg-yellow-600 transition duration-300">Agregar Profesor</a>
            </div>
            {{/is_admin}}

            <!-- TARJETA ALTA MATERIA -->
            {{#is_admin}}
            <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-red-700 dark:text-red-300 mb-3">Materias</h2>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Agrega una materia al sistema.</p>
                <a href="/subject/create" class="inline-block bg-red-500 text-white py-2 px-4 rounded-md hover:bg-red-600 transition duration-300">Agregar Materia</a>
            </div>
            {{/is_admin}}

            <!-- TARJETA ASIGNAR PROFESOR -->
            {{#is_admin}}
            <div class="bg-pink-50 dark:bg-pink-900/30 border border-pink-200 dark:border-pink-800 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-pink-700 dark:text-pink-300 mb-3">Asignar profesor</h2>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Asigna un profesor a una materia.</p>
                <a href="/teacher/assign" class="inline-block bg-pink-500 text-white py-2 px-4 rounded-md hover:bg-pink-600 transition duration-300">Asignar</a>
            </div>
            {{/is_admin}}

            <!-- TARJETA MODIFICACION DE PLAN -->
            {{#is_admin}}
            <div class="bg-indigo-50 dark:bg-indigo-900/30 border border-indigo-200 dark:border-indigo-800 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-indigo-700 dark:text-indigo-300 mb-3">Planes de Estudio</h2>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Actualiza el estado de los planes del sistema.</p>
                <a href="/plan/update" class="inline-block bg-indigo-500 text-white py-2 px-4 rounded-md hover:bg-indigo-600 transition duration-300">Modificar plan</a>
            </div>
            {{/is_admin}}
            
            <!-- TARJETA BAJA DE PROFESOR -->
            {{#is_admin}}
            <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-red-700 dark:text-red-300 mb-3">Baja de Docentes</h2>
                <p class="text-gray-600 dark:text-gray-400 mb-4">Busca y elimina docentes del sistema académico.</p>
                <a href="/teacher/delete" class="inline-block bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 transition duration-300">
                    Baja de docente
                </a>
            </div>
            {{/is_admin}}
            
        </div>

        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">Cerrar Sesión</a>
        </div>
    </div>
</body>
</html>