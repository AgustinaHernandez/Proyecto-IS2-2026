{{> header}}

<body class="bg-gray-100 dark:bg-gray-900 flex items-center justify-center min-h-screen p-4 transition-colors duration-300">
    
    <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-md border border-gray-200 dark:border-gray-700">
        
        <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mb-6">Alta de Materia</h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <form action="/subject/new" method="post" class="space-y-4">
            <div>
                <label for="name" class="block text-gray-700 dark:text-gray-300 text-sm font-medium mb-1">Nombre de la Materia:</label>
                <input type="text" id="name" name="name" placeholder="" required
                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
            </div>

            <div>
                <label for="code" class="block text-gray-700 dark:text-gray-300 text-sm font-medium mb-1">Código de la Materia:</label>
                <input type="number" id="code" name="code" placeholder="" required
                    class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
            </div>
            <div>
                <label for="responsible_id" class="block text-gray-700 dark:text-gray-300 text-sm font-medium mb-1">Docente Responsable:</label>
                <select id="responsible_id" name="responsible_id" required class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                    <option value="" disabled selected>Seleccione un docente</option>
                    {{#teachers}}
                    <option value="{{getId}}">{{getFullNameString}}</option>
                    {{/teachers}}
                </select>
            </div>
            <div>
                <label for="plan_id" class="block text-gray-700 dark:text-gray-300 text-sm font-medium mb-1">Plan de Estudio:</label>
                <select id="plan_id" name="plan_id" required class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                    <option value="" disabled selected>Seleccione un plan de estudio</option>
                    {{#plans}}
                    <option value="{{getId}}">{{getDisplayString}}</option>
                    {{/plans}}
                </select>
            </div>
            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors duration-200">
                Crear Materia
            </button>
            
            <div class="text-center mt-4">
                <a href="/dashboard" class="text-blue-600 dark:text-blue-400 hover:underline text-sm">Volver al Dashboard</a>
            </div>
        </form>
    </div>
</body>
</html>