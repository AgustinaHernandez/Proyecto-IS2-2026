<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Baja de Docentes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class' }; 
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark')
        } else {
            document.documentElement.classList.remove('dark')
        }
        
        // Función para confirmar antes de borrar
        function confirmarEliminacion(nombre) {
            return confirm(' seguro que deseas eliminar al docente ' + nombre + '? Esta acción lo removerá de todas las materias asignadas.');
        }
    </script>
</head>
<body class="bg-gray-100 dark:bg-gray-900 min-h-screen p-8 transition-colors duration-300">
    
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-800 dark:text-white mb-6">Baja de Docentes</h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow mb-8 border border-gray-200 dark:border-gray-700">
            <form action="/teacher/delete" method="get" class="flex gap-4">
                <div class="flex-grow">
                    <input type="text" name="q" value="{{query}}" placeholder="Buscar por Nombre, Apellido o DNI..." 
                           class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white">
                </div>
                <button type="submit" class="bg-gray-600 text-white py-2 px-6 rounded-md hover:bg-gray-700 transition-colors">
                    Buscar
                </button>
            </form>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden border border-gray-200 dark:border-gray-700">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
                        <th class="py-3 px-6 text-sm font-semibold text-gray-700 dark:text-gray-300">DNI</th>
                        <th class="py-3 px-6 text-sm font-semibold text-gray-700 dark:text-gray-300">Nombre Completo</th>
                        <th class="py-3 px-6 text-sm font-semibold text-gray-700 dark:text-gray-300">Acción</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    
                    {{#teachers}}
                    <tr class="hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                        <td class="py-3 px-6 text-sm text-gray-900 dark:text-white font-medium">{{getDNI}}</td>
                        <td class="py-3 px-6 text-sm text-gray-700 dark:text-gray-300">{{getFullNameString}}</td>
                        <td class="py-3 px-6 text-sm">
                            <form action="/teacher/delete" method="post" onsubmit="return confirmarEliminacion('{{getFullNameString}}');">
                                <input type="hidden" name="teacher_id" value="{{getId}}">
                                <button type="submit" class="text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300 font-medium bg-red-100 dark:bg-red-900/30 px-3 py-1 rounded">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                    {{/teachers}}
                    
                    {{^teachers}}
                    <tr>
                        <td colspan="3" class="py-8 text-center text-gray-500 dark:text-gray-400">
                            No se encontraron docentes con esos datos
                        </td>
                    </tr>
                    {{/teachers}}

                </tbody>
            </table>
        </div>
        
        <div class="mt-6 text-center">
            <a href="/dashboard" class="text-blue-600 dark:text-blue-400 hover:underline"><- Anterior</a>
            <a href="/dashboard" class="text-blue-600 dark:text-blue-400 hover:underline">Siguiente -> </a>
        </div>


        <div class="mt-6 text-center">
            <a href="/dashboard" class="text-blue-600 dark:text-blue-400 hover:underline">← Volver al Dashboard</a>
        </div>
    </div>

</body>
</html>