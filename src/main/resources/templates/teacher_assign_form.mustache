{{>header}}

<body class="bg-gray-100 dark:bg-gray-900 flex items-center justify-center min-h-screen p-4 transition-colors duration-300">
    
    <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-md border border-gray-200 dark:border-gray-700">
        <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mb-6">Asignar Profesor</h1>

        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        <form action="/teacher/assign" method="post" class="space-y-6">
            
            <div>
                <label for="subject_id" class="block text-gray-700 dark:text-gray-300 text-sm font-medium mb-1">Materia:</label>
                <select id="subject_id" name="subject_id" required class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                    <option value="" disabled selected>Seleccione una materia</option>
                    {{#subjects}}
                    <option value="{{id}}">{{name}}</option>
                    {{/subjects}}
                </select>
            </div>

            <div class="relative">
                <label for="searchQuery" class="block text-gray-700 dark:text-gray-300 text-sm font-medium mb-1">Buscar Profesor:</label>
                <div class="flex gap-2">
                    <input type="text" id="searchQuery" placeholder="Ej: Juan Pérez" autocomplete="off"
                        class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                    
                    <button type="button" id="searchBtn" 
                            class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500">
                        Buscar
                    </button>
                </div>
                
                <ul id="searchResults" class="absolute z-10 w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-md mt-1 max-h-48 overflow-y-auto hidden shadow-lg">
                </ul>
            </div>

            <div id="selectedTeacherContainer" class="hidden bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 p-3 rounded-md">
                <span class="text-sm text-gray-600 dark:text-gray-400">Profesor Seleccionado:</span>
                <p id="selectedTeacherName" class="font-semibold text-gray-800 dark:text-blue-200"></p>
            </div>
            
            <input type="hidden" id="teacher_id" name="teacher_id" required>

            <button type="submit"
                    class="w-full bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors duration-200 mt-4">
                Confirmar Asignación
            </button>
            
            <div class="text-center mt-4">
                <a href="/dashboard" class="text-blue-600 dark:text-blue-400 hover:underline text-sm">Volver al Dashboard</a>
            </div>
        </form>
    </div>

    <script>
        const searchInput = document.getElementById('searchQuery');
        const searchBtn = document.getElementById('searchBtn');
        const searchResults = document.getElementById('searchResults');
        const teacherIdInput = document.getElementById('teacher_id');
        const selectedContainer = document.getElementById('selectedTeacherContainer');
        const selectedNameDisplay = document.getElementById('selectedTeacherName');

        // función para llamar a la API
        function search(){
            const query = searchInput.value.trim();
            if (query.length === 0) {
                searchResults.classList.add('hidden');
                return;
            }
            fetch(`/api/teachers/search?q=${encodeURIComponent(query)}`)
                .then(response => response.json())
                .then(data => {
                    searchResults.innerHTML = '';
                    if (data.length === 0) {
                        searchResults.innerHTML = '<li class="px-4 py-2 text-gray-500 dark:text-gray-400 text-sm">No se encontraron profesores</li>';
                    } else {
                        data.forEach(teacher => {
                            const li = document.createElement('li');
                            li.className = 'px-4 py-2 hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer text-gray-800 dark:text-gray-200 border-b border-gray-100 dark:border-gray-600 last:border-0';
                            li.innerHTML = `${teacher.fullName} <span class="text-xs text-gray-500 dark:text-gray-400 ml-2">DNI: ${teacher.dni}</span>`;
                            
                            // dispara al seleccionar a alguien de la lista
                            li.addEventListener('click', () => {
                                teacherIdInput.value = teacher.id;
                                selectedNameDisplay.textContent = teacher.fullName;
                                selectedContainer.classList.remove('hidden');
                                searchResults.classList.add('hidden'); // esconder la lista
                            });
                            searchResults.appendChild(li);
                        });
                    }
                    searchResults.classList.remove('hidden');
                })
                .catch(error => console.error('Error en la búsqueda:', error));
        }

        // hacer la búsqueda al hacer click en el botón o apretar enter estando en el textbox
        searchBtn.addEventListener('click', search);
        searchInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault(); // evitar que el formulario principal haga submit por error
                search();
            }
        });
        // esconder resultados al hacer click afuera
        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !searchBtn.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.classList.add('hidden');
            }
        });
    </script>
</body>
</html>