{{> header}}

<body class="bg-gray-100 dark:bg-gray-900 min-h-screen p-4 transition-colors duration-300 flex justify-center items-start pt-10">
    
    <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-5xl border border-gray-200 dark:border-gray-700">

    <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mb-6">Rendimiento académico ({{mode}})</h1>

        <div class="relative overflow-x-auto shadow-sm sm:rounded-lg border border-gray-200 dark:border-gray-700 mb-6">
            <table class="w-full text-sm text-left text-gray-700 dark:text-gray-300">
                <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                    <tr>
                        <th scope="col" class="px-6 py-3">Código</th>
                        <th scope="col" class="px-6 py-3">Nombre</th>
                        <th scope="col" class="px-6 py-3">Año</th>
                        <th scope="col" class="px-6 py-3">Nota</th>
                    </tr>
                </thead>
                
                <tbody>
                    {{#subjects}}
                    <tr class="bg-white border-b dark:border-gray-700 dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200">
                        <td class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-white">
                            {{code}}
                        </td>
                        <td class="px-6 py-4">{{name}}</td>
                        <td class="px-6 py-4">{{year}}</td>
                        <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400">{{grade}}</td>
                    </tr>
                    {{/subjects}}
                    {{^subjects}}
                        <tr class="bg-white dark:bg-gray-800">
                            <td colspan="5" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">
                                No se encontraron materias {{#both}}aprobadas ni desaprobadas{{/both}}{{^both}}{{mode}}{{/both}}.
                            </td>
                        </tr>
                    {{/subjects}}
                </tbody>
            </table>

        {{#hasSubjects}}
        <div class="mt-4 mb-8">
            <h2 class="text-lg font-bold text-gray-800 dark:text-white mb-3 px-1">Promedios de notas</h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 flex items-center justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Promedio sin aplazos</p>
                        <p class="text-2xl font-extrabold text-blue-600 dark:text-blue-400">{{approvedAverage}}</p>
                    </div>
                    <div class="w-10 h-10 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                    </div>
                </div>

                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 flex items-center justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Promedio con aplazos</p>
                        <p class="text-2xl font-extrabold text-indigo-600 dark:text-indigo-400">{{totalAverage}}</p>
                    </div>
                    <div class="w-10 h-10 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                    </div>
                </div>

            </div>
        </div>
        {{/hasSubjects}}

        <div class="flex justify-center mt-6">
            <a href="/academic-performance" class="bg-blue-600 text-white py-2 px-6 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors duration-200 text-center shadow-sm">
                Volver al panel principal
            </a>
        </div>

    </div>
</body>
</html>