{{>header}}

<body class="bg-gray-100 dark:bg-gray-900 flex items-center justify-center min-h-screen p-4 transition-colors duration-300">
    
    <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-md border border-gray-200 dark:border-gray-700">
        <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mb-2">Inscripción a Asignaturas</h1>
        <p class="text-sm text-center text-gray-500 dark:text-gray-400 mb-6">El sistema filtra automáticamente las asignaturas según el avance de tu plan y correlativas.</p>

        {{#success}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{success}}</span>
        </div>
        {{/success}}

        {{#error}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{error}}</span>
        </div>
        {{/error}}

        <form action="/enrollment" method="POST" class="space-y-6">
            
            <div>
                <label for="subject_id" class="block text-gray-700 dark:text-gray-300 text-sm font-medium mb-1">Materias habilitadas para el período actual:</label>
                
                {{^materias}}
                <div class="p-4 bg-yellow-50 dark:bg-yellow-900/30 border border-yellow-200 dark:border-yellow-800 text-yellow-800 dark:text-yellow-200 rounded-md text-sm mt-2">
                    No posees materias disponibles para inscribirte en este momento (verifica tus correlativas o si ya te inscribiste).
                </div>
                {{/materias}}

                {{#hasMaterias}}
                <select id="subject_id" name="subject_id" required class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white mt-1">
                    <option value="" disabled selected>Elige una materia</option>
                    {{#materias}}
                        <option value="{{id}}">[{{code}}] {{name}}</option>
                    {{/materias}}
                </select>
                {{/hasMaterias}}
            </div>

            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors duration-200 mt-4 disabled:opacity-50 disabled:cursor-not-allowed" 
                    {{^materias}}disabled{{/materias}}>
                Confirmar Inscripción
            </button>
            
            <div class="text-center mt-4">
                <a href="/dashboard" class="text-blue-600 dark:text-blue-400 hover:underline text-sm">Volver al Dashboard</a>
            </div>
        </form>
    </div>

</body>
</html>