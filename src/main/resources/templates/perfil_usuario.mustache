{{> header}}

<body class="bg-gray-100 dark:bg-gray-900 flex items-center justify-center min-h-screen p-4 transition-colors duration-300">

    <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow-2xl w-full max-w-2xl transform transition-all duration-500 hover:shadow-xl border border-transparent dark:border-gray-700">
        
        <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mb-6">Mi Perfil</h1>

        <div class="space-y-4 mb-8 p-6 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl">
            <div class="flex justify-between items-center">
                <span class="font-semibold text-gray-700 dark:text-gray-300">ID de Cuenta:</span>
                <span class="text-gray-800 dark:text-gray-200 font-mono text-sm bg-blue-100 dark:bg-blue-900 px-2 py-1 rounded-md border border-blue-200 dark:border-blue-700">
                    {{userId}}
                </span>
            </div>

            <div class="flex justify-between border-b border-blue-200 dark:border-blue-800 pb-2">
                <span class="font-semibold text-gray-700 dark:text-gray-300">Nombre de Usuario:</span>
                <span class="font-extrabold text-blue-700 dark:text-blue-400">{{username}}</span>
            </div>

            <div class="flex justify-between border-b border-blue-200 dark:border-blue-800 pb-2">
                <span class="font-semibold text-gray-700 dark:text-gray-300">Nombre completo:</span>
                <span class="font-extrabold text-blue-700 dark:text-blue-400">{{fullName}}</span>
            </div>

            <div class="flex justify-between border-b border-blue-200 dark:border-blue-800 pb-2">
                <span class="font-semibold text-gray-700 dark:text-gray-300">DNI:</span>
                <span class="font-extrabold text-blue-700 dark:text-blue-400">{{dni}}</span>
            </div>

            <div class="flex justify-between border-b border-blue-200 dark:border-blue-800 pb-2">
                <span class="font-semibold text-gray-700 dark:text-gray-300">Correo electrónico:</span>
                <span class="font-extrabold text-blue-700 dark:text-blue-400">{{email}}</span>
            </div>
            {{#degree}} {{! Si es null (no es un profesor, por ende degree no es "truthy"), no se renderiza}}
                <div class="flex justify-between border-b border-blue-200 dark:border-blue-800 pb-2">
                    <span class="font-semibold text-gray-700 dark:text-gray-300">Título:</span>
                    <span class="font-extrabold text-blue-700 dark:text-blue-400">{{degree}}</span>
                </div>
            {{/degree}}

        </div>
        
        <div class="flex flex-col sm:flex-row justify-center gap-4 mt-8">
            <a href="/change-password" class="inline-flex items-center justify-center bg-blue-600 dark:bg-blue-500 text-white py-2 px-6 rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 transition duration-300 text-lg shadow-md font-semibold">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z" />
                </svg>
                Cambiar Contraseña
            </a>

            <a href="/dashboard" class="inline-flex items-center justify-center bg-gray-600 dark:bg-gray-700 text-white py-2 px-6 rounded-lg hover:bg-gray-700 dark:hover:bg-gray-600 transition duration-300 text-lg shadow-md font-semibold">
                Volver al Panel
            </a>
        </div>
    </div>

</body>
</html>